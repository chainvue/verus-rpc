# Gated integration tests (see docs/testing-live.md).
# Unset → integration suites skip; set → they run against this node.
# Real credentials come from the node host via SSH — never commit them.
VERUS_RPC_URL=http://127.0.0.1:18843
VERUS_RPC_USER=
VERUS_RPC_PASS=

# Second explicit flag: value-moving WRITE harness (dust sends, a fresh
# throwaway identity, best-effort shielded + marketplace) on VRSCTEST only.
# Leave unset unless you know exactly what you are doing — see docs/testing-live.md.
# VERUS_RPC_ALLOW_SPEND=1

# Third flag: after a write-harness run, promote sanitized captures into
# fixtures/ (replaces the synthetic write-method fixtures). Off by default.
# VERUS_RPC_RECORD_FIXTURES=1

# Read-only shape smoke against public mainnet (independent of the above).
# VERUS_RPC_MAINNET_SMOKE=1
