# Gated integration tests (ring 3, see DESIGN.md §5).
# Unset → integration suites skip; set → they run against this node.
# Real credentials come from the node host via SSH — never commit them.
VERUS_RPC_URL=http://127.0.0.1:18843
VERUS_RPC_USER=
VERUS_RPC_PASS=

# Second explicit flag: value-moving tests (dust sends on VRSCTEST only).
# Leave unset unless you know exactly what you are doing.
# VERUS_RPC_ALLOW_SPEND=1
