{
  "name": "@chainvue/verus-rpc",
  "version": "0.3.0",
  "description": "Precision-honest TypeScript client for the Verus (verusd) JSON-RPC interface — daemon-first, npm-published. Every daemon method reachable via call(); the common surface is curated with precise types.",
  "license": "Apache-2.0",
  "author": "Robert Lech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chainvue/verus-rpc.git"
  },
  "homepage": "https://github.com/chainvue/verus-rpc#readme",
  "bugs": {
    "url": "https://github.com/chainvue/verus-rpc/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "verus",
    "verusd",
    "vrsc",
    "rpc",
    "json-rpc",
    "verusid",
    "pbaas",
    "blockchain"
  ],
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:live": "vitest run test/integration.test.ts test/spend.integration.test.ts test/public-node.integration.test.ts",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "semantic-release": "^25.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "cockatiel": "^4.0.0",
    "lossless-json": "^4.3.0"
  }
}
